{
	"name": "saitho/legacy-icons",
	"type": "typo3-cms-extension",
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "Mario Lubenka",
			"role": "Developer"
		},
		{
			"name": "The TYPO3 Community",
			"role": "Contributor",
			"homepage": "https://typo3.org/community/"
		}
	],
	"require": {
		"typo3/cms-filelist": "^14.0"
	},
	"extra": {
		"typo3/cms": {
			"extension-key": "legacy_icons"
		}
	},
    "scripts": {
        "build:cleanup": [
            "git reset --hard",
            "git clean -xfd"
        ],
        "deploy:ter:setup": [
            "@composer global require clue/phar-composer typo3/tailor"
        ],
        "deploy:ter:upload": [
            "composer global exec -v -- tailor ter:publish --comment \"$(git tag -l --format='%(contents)' $TAG)\" ${TAG#v}"
        ],
        "deploy:ter": [
            "@build:cleanup",
            "@deploy:ter:setup",
            "@deploy:ter:upload"
        ]
    }
}
